<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All-in-One Infinite Image Gallery</title>
    <style>
        /* --- CSS STYLING --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f6f9;
            color: #333;
            padding: 2rem 1rem;
        }

        .gallery-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        h1 {
            text-align: center;
            margin-bottom: 2rem;
            color: #2c3e50;
        }

        /* Responsive Grid Layout */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }

        /* Gallery Item & Smooth Transitions */
        .gallery-item {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 8px rgba(0,0,0,0.05);
            cursor: pointer;
            background-color: #e2e8f0;
            aspect-ratio: 4 / 3;
        }

        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
        }

        /* Hover Zoom Effect */
        .gallery-item:hover img {
            transform: scale(1.08);
        }

        /* Loading Spinner at Bottom */
        .loading {
            display: flex;
            justify-content: center;
            padding: 3rem 0;
            width: 100%;
        }

        .spinner {
            width: 40px;
            height: 40px;
            border: 4px solid #e2e8f0;
            border-top: 4px solid #3498db;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Lightbox Modal Structure */
        .lightbox {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.92);
            display: flex;
            justify-content: center;
            align-items: center;
            opacity: 0;
            pointer-events: none;
            z-index: 1000;
            transition: opacity 0.4s ease;
        }

        .lightbox.active {
            opacity: 1;
            pointer-events: auto;
        }

        .lightbox-content {
            max-width: 85%;
            max-height: 80%;
            position: relative;
        }

        #lightbox-img {
            max-width: 100%;
            max-height: 80vh;
            border-radius: 4px;
            box-shadow: 0 5px 25px rgba(0,0,0,0.5);
            transform: scale(0.95);
            transition: transform 0.4s ease;
        }

        .lightbox.active #lightbox-img {
            transform: scale(1);
        }

        /* Close and Navigation Controls */
        .close-btn {
            position: absolute;
            top: 20px;
            right: 30px;
            color: #ccc;
            font-size: 45px;
            font-weight: 300;
            cursor: pointer;
            transition: color 0.2s;
            user-select: none;
        }

        .close-btn:hover {
            color: #fff;
        }

        .nav-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255, 255, 255, 0.08);
            color: #fff;
            border: none;
            font-size: 28px;
            padding: 14px 20px;
            cursor: pointer;
            border-radius: 50%;
            transition: background 0.2s, transform 0.2s translateY(-50%);
            user-select: none;
        }

        .nav-btn:hover {
            background: rgba(255, 255, 255, 0.25);
        }

        .prev-btn { left: 20px; }
        .next-btn { right: 20px; }

        @media (max-width: 600px) {
            .nav-btn {
                padding: 10px 14px;
                font-size: 20px;
            }
            .prev-btn { left: 10px; }
            .next-btn { right: 10px; }
        }
    </style>
</head>
<body>

    <div class="gallery-container">
        <h1>Infinite Scroll Image Gallery</h1>
        
        <div class="gallery-grid" id="gallery-grid"></div>
        
        <div class="loading" id="loading-trigger">
            <div class="spinner"></div>
        </div>
    </div>

    <div class="lightbox" id="lightbox">
        <span class="close-btn" id="close-btn">&times;</span>
        <button class="nav-btn prev-btn" id="prev-btn">&#10094;</button>
        <div class="lightbox-content">
            <img id="lightbox-img" src="" alt="Gallery Preview">
        </div>
        <button class="nav-btn next-btn" id="next-btn">&#10095;</button>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const galleryGrid = document.getElementById("gallery-grid");
            const loadingTrigger = document.getElementById("loading-trigger");
            
            const lightbox = document.getElementById("lightbox");
            const lightboxImg = document.getElementById("lightbox-img");
            const closeBtn = document.getElementById("close-btn");
            const prevBtn = document.getElementById("prev-btn");
            const nextBtn = document.getElementById("next-btn");

            let page = 1;
            const batchLimit = 12; // Number of images to fetch per load loop
            let loadedImagesUrls = []; // Track source URLs for modal navigation
            let currentIndex = 0;
            let isLoading = false;

            // 1. Fetching imagery stream from dynamic API resource
            async function loadMoreImages() {
                if (isLoading) return;
                isLoading = true;

                try {
                    const response = await fetch(`https://picsum.photos/v2/list?page=${page}&limit=${batchLimit}`);
                    const imagesData = await response.json();

                    if (imagesData.length === 0) {
                        loadingTrigger.style.display = 'none'; // Stop if reached the absolute end
                        return;
                    }

                    imagesData.forEach(imageData => {
                        // Creating dynamic size mapping URL blocks 
                        const highResUrl = `https://picsum.photos/id/${imageData.id}/1200/900`;
                        loadedImagesUrls.push(highResUrl);
                        
                        // Construct DOM structures securely
                        const itemContainer = document.createElement("div");
                        itemContainer.classList.add("gallery-item");
                        
                        const imageElement = document.createElement("img");
                        imageElement.src = `https://picsum.photos/id/${imageData.id}/500/375`; // Lighter size thumbnail
                        imageElement.alt = `Photo curated by ${imageData.author}`;
                        imageElement.loading = "lazy"; // Native browser rendering resource saver

                        // Capture current index context within the scope
                        const activeImageIndex = loadedImagesUrls.length - 1;
                        itemContainer.addEventListener("click", () => showLightbox(activeImageIndex));

                        itemContainer.appendChild(imageElement);
                        galleryGrid.appendChild(itemContainer);
                    });

                    page++; // Adjust pointer to pull fresh set next loop
                } catch (err) {
                    console.error("Failed to query live image payload streams:", err);
                } finally {
                    isLoading = false;
                }
            }

            // 2. Lightbox Control Functions
            function showLightbox(index) {
                currentIndex = index;
                lightboxImg.src = loadedImagesUrls[currentIndex];
                lightbox.classList.add("active");
                document.body.style.overflow = "hidden"; // Freeze scroll when viewing modal
            }

            function hideLightbox() {
                lightbox.classList.remove("active");
                document.body.style.overflow = "auto"; // Restore scroll
            }

            function changeImage(direction) {
                if (direction === 'next') {
                    currentIndex = (currentIndex + 1) % loadedImagesUrls.length;
                } else if (direction === 'prev') {
                    currentIndex = (currentIndex - 1 + loadedImagesUrls.length) % loadedImagesUrls.length;
                }
                lightboxImg.src = loadedImagesUrls[currentIndex];
            }

            // 3. Setup Interactive Listeners
            closeBtn.addEventListener("click", hideLightbox);
            nextBtn.addEventListener("click", () => changeImage('next'));
            prevBtn.addEventListener("click", () => changeImage('prev'));
            
            // Close lightbox when clicking the empty background space
            lightbox.addEventListener("click", (e) => {
                if (e.target === lightbox) hideLightbox();
            });

            // Native Desktop Keyboard Navigation Mapping
            document.addEventListener("keydown", (e) => {
                if (!lightbox.classList.contains("active")) return;
                if (e.key === "Escape") hideLightbox();
                if (e.key === "ArrowRight") changeImage('next');
                if (e.key === "ArrowLeft") changeImage('prev');
            });

            // 4. Intersection Observer: Detects when loading spinner gets close to view
            const scrollObserver = new IntersectionObserver((entries) => {
                if (entries[0].isIntersecting && !isLoading) {
                    loadMoreImages();
                }
            }, {
                rootMargin: "300px" // Pre-loads next batch 300px before reaching screen baseline
            });

            // Start Monitoring the Spinner element
            scrollObserver.observe(loadingTrigger);
        });
    </script>
</body>
</html>
